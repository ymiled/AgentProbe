{
  "manifest_version": "0.1.0",
  "program": {
    "image": "ghcr.io/ymiled/agentprobe:latest",
    "entrypoint": ["sh", "run.sh"],
    "env": {
      "HOST": "0.0.0.0",
      "AGENT_PORT": "8090",
      "AMBER_HINT_PROXY": "${slots.proxy}",
      "GOOGLE_API_KEY": "${config.google_api_key}",
      "GEMINI_API_KEY": "${config.google_api_key}",
      "AGENTPROBE_LLM_PROVIDER": "google",
      "AGENTPROBE_LLM_MODEL": "gemini-2.0-flash",
      "AGENTPROBE_LLM_API_KEY_ENV": "GOOGLE_API_KEY"
    },
    "network": {
      "endpoints": [
        { "name": "endpoint", "port": 8090 }
      ]
    }
  },
  "slots": {
    "proxy": { "kind": "a2a" }
  },
  "provides": {
    "a2a": { "kind": "a2a", "endpoint": "endpoint" }
  },
  "exports": {
    "a2a": "a2a"
  },
  "config_schema": {
    "type": "object",
    "properties": {
      "google_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "metadata": {
    "name": "AgentProbe",
    "description": "Security red-team benchmark for AI agents. Runs structured adversarial attacks and returns OWASP-aligned vulnerability reports.",
    "contact": "youssef.miled7@gmail.com",
    "homepage": "https://github.com/ymiled/AgentProbe",
    "license": "MIT"
  }
}
