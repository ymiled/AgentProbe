{
  "manifest_version": "0.1.0",
  "program": {
    "image": "ghcr.io/ymiled/agentprobe:latest",
    "entrypoint": ["sh", "run.sh"],
    "env": {
      "HOST": "0.0.0.0",
      "AGENT_PORT": "8090",
      "AMBER_HINT_PROXY": "${slots.proxy}",
      "ANTHROPIC_API_KEY": "${config.ANTHROPIC_API_KEY}"
    },
    "network": {
      "endpoints": [
        { "name": "endpoint", "port": 8090 }
      ]
    }
  },
  "slots": {
    "proxy": { "kind": "a2a" }
  },
  "provides": {
    "a2a": { "kind": "a2a", "endpoint": "endpoint" }
  },
  "exports": {
    "a2a": "a2a"
  },
  "config_schema": {
    "type": "object",
    "properties": {
      "ANTHROPIC_API_KEY": {
        "type": "string",
        "description": "Anthropic API key for LLM-based attack generation"
      }
    },
    "required": ["ANTHROPIC_API_KEY"]
  },
  "metadata": {
    "name": "AgentProbe",
    "description": "Security red-team benchmark for AI agents. Runs structured adversarial attacks and returns OWASP-aligned vulnerability reports.",
    "contact": "youssef.miled7@gmail.com",
    "homepage": "https://github.com/ymiled/AgentProbe",
    "license": "MIT"
  }
}
