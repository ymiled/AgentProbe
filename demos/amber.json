{
  "manifest_version": "0.1.0",
  "program": {
    "image": "ghcr.io/ymiled/agentprobe-demo-competitor:latest",
    "entrypoint": ["python", "demos/demo_evaluator_agent.py"],
    "env": {
      "HOST": "0.0.0.0",
      "AGENT_PORT": "8081",
      "ANTHROPIC_API_KEY": "${config.anthropic_api_key}"
    },
    "network": {
      "endpoints": [
        { "name": "endpoint", "port": 8081 }
      ]
    }
  },
  "provides": {
    "a2a": { "kind": "a2a", "endpoint": "endpoint" }
  },
  "exports": {
    "a2a": "a2a"
  },
  "config_schema": {
    "type": "object",
    "properties": {
      "anthropic_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "metadata": {
    "name": "AgentProbe Demo Competitor Agent",
    "description": "A vulnerable financial analyst agent for benchmarking and attack simulation.",
    "contact": "youssef.miled7@gmail.com",
    "homepage": "https://github.com/ymiled/AgentProbe",
    "license": "MIT"
  }
}
